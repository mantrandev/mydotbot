{
  "permissions": {
    "deny": [
      "mcp__computer-use__*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/maybe/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/maybe/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "warp@claude-code-warp": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "visual-explainer@visual-explainer-marketplace": true
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    },
    "visual-explainer-marketplace": {
      "source": {
        "source": "github",
        "repo": "nicobailon/visual-explainer"
      }
    }
  },
  "outputStyle": "Explanatory",
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "tui": "default",
  "theme": "dark",
  "editorMode": "normal",
  "preferredNotifChannel": "auto",
  "autoCompactEnabled": false,
  "skipAutoPermissionPrompt": true,
  "model": "opus[1m]"
}
